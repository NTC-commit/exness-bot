import os
import asyncio
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from dotenv import load_dotenv

# Đọc API Key từ file .env
load_dotenv()
API_TOKEN = os.getenv('API_TOKEN')

# Khởi tạo bot
bot = Bot(token=API_TOKEN)
dp = Dispatcher()

# Biến lưu tỉ giá mặc định
CURRENT_RATE = 25000 

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer("Chào mày! Nhập số tiền VNĐ đi, tao tính ra USDT cho.")

@dp.message(Command("setrate"))
async def set_rate(message: types.Message):
    global CURRENT_RATE
    try:
        new_rate = float(message.text.split()[1])
        CURRENT_RATE = new_rate
        await message.answer(f"✅ Đã chốt tỉ giá mới: {CURRENT_RATE:,.0f} VND/USDT")
    except:
        await message.answer("⚠️ Lỗi lệnh. Hãy gõ ví dụ: /setrate 26000")

@dp.message(F.text.regexp(r'^\d+([.,]\d+)?$'))
async def convert_handler(message: types.Message):
    try:
        # Lọc bỏ dấu phẩy, dấu chấm người dùng nhập vào cho chuẩn
        vnd_amount = float(message.text.replace(',', '').replace('.', ''))
        usdt_amount = vnd_amount / CURRENT_RATE
        
        await message.answer(
            f"💰 {vnd_amount:,.0f} VND ≈ **{usdt_amount:.2f} USDT**\n"
            f"(Tỉ giá đang áp dụng: {CURRENT_RATE:,.0f})"
        )
    except:
        await message.answer("⚠️ Lỗi tính toán, hãy nhập con số đàng hoàng.")

async def main():
    await dp.start_polling(bot)

if __name__ == '__main__':
    asyncio.run(main())